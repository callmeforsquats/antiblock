{
  "log": {
    "loglevel": "warning"
  },

  "inbounds": [
    {
      "tag": "from-entry-reality",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "${UUID_FROM_ENTRY}",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "www.cloudflare.com:443",
          "serverNames": ["www.cloudflare.com"],
          "privateKey": "${EXIT_REALITY_PRIVATE_KEY}",
          "shortIds": ["${EXIT_SHORT_ID}"]
        }
      }
    }
  ],

  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}