{
  "tag": "from-entry",
  "listen": "0.0.0.0",
  "port": 443,
  "protocol": "vless",

  "settings": {
    "clients": [
      {
        "id": "{{UUID_FROM_ENTRY}}"
      }
    ],
    "decryption": "none"
  },

  "streamSettings": {
    "network": "tcp",
    "security": "reality",
    "realitySettings": {
      "show": false,
      "dest": "www.cloudflare.com:443",
      "xver": 0,
      "serverNames": [
        "www.cloudflare.com"
      ],
      "privateKey": "{{EXIT_REALITY_PRIVATE_KEY}}",
      "shortIds": [
        "{{EXIT_SHORT_ID}}"
      ]
    }
  }
}