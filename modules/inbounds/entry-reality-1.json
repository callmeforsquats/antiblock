{
  "tag": "entry-reality-1",
  "listen": "0.0.0.0",
  "port": 443,
  "protocol": "vless",

  "settings": {
    "clients": [
      {
        "id": "{{UUID}}",
        "flow": "xtls-rprx-vision"
      }
    ],
    "decryption": "none"
  },

  "streamSettings": {
    "network": "tcp",
    "security": "reality",
    "realitySettings": {
      "show": false,
      "dest": "www.cloudflare.com:443",
      "xver": 0,
      "serverNames": [
        "www.cloudflare.com"
      ],
      "privateKey": "{{REALITY_PRIVATE_KEY}}",
      "shortIds": [
        "{{SHORT_ID_PRIMARY}}"
      ]
    }
  }
}