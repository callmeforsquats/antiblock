{
  "tag": "enter-tls-ws",
  "listen": "127.0.0.1",
  "port": 10000,
  "protocol": "vless",

  "settings": {
    "clients": [
      {
        "id": "{{UUID}}"
      }
    ],
    "decryption": "none"
  },

  "streamSettings": {
    "network": "ws",
    "security": "none",
    "wsSettings": {
      "path": "/ws-path",
      "headers": {}
    }
  }
}